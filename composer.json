        "similarity",
        "comparison",
        "phpcomparison",
        "PHP"
    ],
    "authors": [
        {
            "name": "Danil Vikulov",
            "email": "vikulovd15@gmail.com"
        }
    ],
    "type": "library",
    "license": "Apache-2.0",
    "minimum-stability": "stable",
    "homepage": "https://similarity.deevee.ru",
    "require": {
        "php": ">=8.1",
        "cijic/phpmorphy": "^0.3.6"
    },
